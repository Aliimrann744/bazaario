{
  "expo": {
    "name": "Bazaario",
    "slug": "bazaario-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bazaario",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D9488"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pk.bazaario.mobile"
    },
    "android": {
      "package": "pk.bazaario.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D9488"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "https://de7f-144-48-133-159.ngrok-free.app",
      "eas": {
        "projectId": "8f09be5b-883a-4cf2-aabf-ba61bd353058"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
