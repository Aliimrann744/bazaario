// Bazaario marketplace — Prisma schema (PostgreSQL)
// Mirrors the domain model in SHARED-SPEC.md §3. JSON columns map to jsonb.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  publicId        String   @unique
  name            String
  email           String?  @unique
  phone           String?  @unique
  passwordHash    String
  avatarUrl       String?
  bio             String?  @db.VarChar(200)
  cityId          String?
  isPhoneVerified Boolean  @default(false)
  isBusiness      Boolean  @default(false)
  businessName    String?
  trustTier       String   @default("NEW") // NEW | ACTIVE | VERIFIED
  role            String   @default("USER") // USER | MODERATOR | ADMIN
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listings            Listing[]
  favourites          Favourite[]
  savedSearches       SavedSearch[]
  buyerConversations  Conversation[] @relation("BuyerConvos")
  sellerConversations Conversation[] @relation("SellerConvos")
  messages            Message[]
  reports             Report[]

  @@map("users")
}

model Location {
  id       String   @id
  parentId String?
  level    String // country | province | city | area
  name     String
  slug     String?
  lat      Float?
  lon      Float?

  parent   Location?  @relation("LocationTree", fields: [parentId], references: [id])
  children Location[] @relation("LocationTree")
  listings Listing[]

  @@index([parentId])
  @@index([level])
  @@map("locations")
}

model Category {
  id                String   @id // e.g. "vehicles.cars"
  parentId          String?
  slug              String?
  label             String
  icon              String?
  listingKind       String   @default("good")
  priceTypesAllowed Json     @default("[]")
  schemaVersion     String   @default("1.0.0")
  schemaRef         String? // JSON category id whose detailed schema this leaf uses
  hasSchema         Boolean  @default(false)
  sortOrder         Int      @default(0)
  isLeaf            Boolean  @default(false)
  isActive          Boolean  @default(true)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  listings Listing[]

  @@index([parentId])
  @@map("categories")
}

model ReferenceItem {
  id       Int     @id @default(autoincrement())
  catalog  String // car_makes, car_models, ...
  parentId String? // parent value (e.g. make value for a model)
  value    String
  label    String

  @@index([catalog])
  @@map("reference_items")
}

model Listing {
  id             String    @id @default(cuid())
  publicId       String    @unique
  userId         String
  categoryId     String
  title          String
  description    String
  priceMinor     BigInt    @default(0)
  priceType      String    @default("fixed")
  currency       String    @default("PKR")
  condition      String?
  locationId     String?
  attributes     Json      @default("{}")
  schemaVersion  String    @default("1.0.0")
  state          String    @default("PENDING_REVIEW")
  rejectionReason String?
  isFeatured     Boolean   @default(false)
  featuredUntil  DateTime?
  viewCount      Int       @default(0)
  favouriteCount Int       @default(0)
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  seller        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id])
  location      Location?      @relation(fields: [locationId], references: [id])
  media         ListingMedia[]
  favourites    Favourite[]
  conversations Conversation[]

  @@index([categoryId])
  @@index([locationId])
  @@index([state])
  @@index([userId])
  @@map("listings")
}

model ListingMedia {
  id        String  @id @default(cuid())
  listingId String
  url       String
  sortOrder Int     @default(0)
  width     Int?
  height    Int?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_media")
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("favourites")
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  query     Json     @default("{}")
  cadence   String   @default("daily")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

model Conversation {
  id            String    @id @default(cuid())
  listingId     String
  buyerId       String
  sellerId      String
  lastMessageAt DateTime?
  buyerReadAt   DateTime?
  sellerReadAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User      @relation("BuyerConvos", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("SellerConvos", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([listingId, buyerId])
  @@map("conversations")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  type           String    @default("text") // text | system
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  targetType String // listing | user
  targetId   String
  reason     String
  detail     String?
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@map("reports")
}
